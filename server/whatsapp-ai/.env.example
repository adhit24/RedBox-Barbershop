# ─── SERVER ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── WHATSAPP CLOUD API ───────────────────────────────
# Dapatkan dari: https://developers.facebook.com/apps/
# → App → WhatsApp → API Setup
# Setiap cabang punya WA_PHONE_NUMBER_ID & WA_ACCESS_TOKEN sendiri
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
WA_VERIFY_TOKEN=redbox_webhook_secret_2026

# ─── OPENAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# ─── BRANCH IDENTITY ──────────────────────────────────
# Identitas cabang yang menjalankan instance bot ini
# BRANCH_NAME: Bypass | CSB | Samadikun | Sumber | Tegal
BRANCH_NAME=Bypass
BRANCH_ADDRESS=Jl. Ahmad Yani No.88, Cirebon

# ─── KAPSTER WA NUMBERS (notifikasi booking) ──────────
# Nomor WA personal para kapster di cabang ini
# Format: comma-separated 628xxxxxxxxxx (tanpa spasi)
# Contoh: KAPSTER_WA=628111000001,628111000002,628111000003
KAPSTER_WA=628111000001,628111000002

# ─── ADMIN ────────────────────────────────────────────
# Nomor admin utama — menerima escalation & backup notifikasi booking
# Format: 628xxxxxxxxxx (no + or spaces)
ADMIN_WHATSAPP=628123456789

# ─── HUMAN HANDOFF ────────────────────────────────────
# Durasi handoff (menit) saat admin manual membalas — bot akan diam selama ini
# Default: 30 menit
HANDOFF_DURATION_MINUTES=30

# ─── REMINDER SCHEDULER ───────────────────────────────
# Quiet hours: no reminders sent before QUIET_START or after QUIET_END (WIB, 24h format)
# Default: 8 = 08:00, 21 = 21:00
REMINDER_QUIET_START=8
REMINDER_QUIET_END=21
