{
  "outputDirectory": ".",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    },
    "api/ai/analyze.js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    },
    "api/ai/upload.js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "redirects": [
    { "source": "/",               "destination": "/maintenance.html", "permanent": false },
    { "source": "/index.html",     "destination": "/maintenance.html", "permanent": false },
    { "source": "/booking.html",   "destination": "/maintenance.html", "permanent": false },
    { "source": "/membership.html","destination": "/maintenance.html", "permanent": false },
    { "source": "/products.html",  "destination": "/maintenance.html", "permanent": false },
    { "source": "/packages.html",  "destination": "/maintenance.html", "permanent": false },
    { "source": "/crm.html",       "destination": "/maintenance.html", "permanent": false },
    { "source": "/sundaze.html",   "destination": "/maintenance.html", "permanent": false },
    { "source": "/api/(.*)",       "destination": "/maintenance.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/Brand_assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
