# ================================================
# REDBOX BARBERSHOP — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================================

# Supabase Project URL (from: Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase Service Role Key (from: Project Settings > API > service_role)
# WARNING: Keep this secret! Never expose in frontend
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# MySQL / XAMPP (aktif jika DATABASE_TYPE=mysql)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=redbox_db

# Pilih database: 'supabase' atau 'mysql'
DATABASE_TYPE=supabase

# Server config
PORT=3001
NODE_ENV=development

# Admin password untuk akses CRM — gunakan password yang kuat!
ADMIN_PASSWORD=ganti_dengan_password_kuat_anda

# CORS: daftar origin yang diizinkan (pisahkan dengan koma)
# Development: biarkan kosong atau isi localhost
# Production: isi dengan domain asli, misal https://redboxbarbershop.com
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Airtable bookings (opsional)
AIRTABLE_API_KEY=your_airtable_pat
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Bookings Redbox

# Airtable kapster (source data utama kapster)
AIRTABLE_BARBERS_TABLE_NAME=Barbers

# Auto sync kapster saat server start
AUTO_SYNC_BARBERS=0

# Legacy fallback Google Sheets (opsional, hanya jika masih dipakai)
BARBERS_SHEET_URL=https://docs.google.com/spreadsheets/d/...

# ================================================
# APP BASE URL (used for Moka per-order callback URLs)
# Must be publicly reachable by Moka servers (use ngrok for local dev)
APP_BASE_URL=https://yourdomain.com

# ================================================
# MOKA POS — OAuth 2.0 Integration
# Register your app at: https://developer.mokapos.com
# ================================================

# OAuth credentials (from Moka Developer Portal)
MOKA_CLIENT_ID=your_moka_client_id
MOKA_CLIENT_SECRET=your_moka_client_secret

# The URL Moka redirects to after user grants access
# Must match exactly what you registered in Moka Developer Portal
MOKA_REDIRECT_URI=https://yourdomain.com/api/moka/callback

# OAuth endpoints (defaults shown — only override if Moka changes them)
MOKA_AUTH_URL=https://account.mokapos.com/oauth/authorize
MOKA_TOKEN_URL=https://api.mokapos.com/oauth/token

# Moka REST API base URL
MOKA_API_BASE=https://api.mokapos.com

# Static token (opsional) — pakai ini jika belum setup OAuth token store
# Bisa diisi akses token / API token yang valid untuk Moka API
MOKA_ACCESS_TOKEN=

# Moka outlet ID (shown in Moka dashboard > Settings > Outlet)
# Used as fallback if not stored per-outlet in moka_tokens table
MOKA_OUTLET_ID=your_moka_outlet_id

# Outlet ID khusus cabang bypass (kalau beda dengan default)
MOKA_OUTLET_ID_BYPASS=

# Auto-push ke Moka saat booking dibuat (hanya untuk cabang di MOKA_PUSH_BRANCHES)
MOKA_PUSH_ON_BOOKING=0
MOKA_PUSH_BRANCHES=bypass

# Payment type yang sudah di-whitelist oleh Moka untuk Advanced Ordering
# Default: online_booking
MOKA_PAYMENT_TYPE=online_booking

# Mapping item default untuk Advanced Ordering (wajib jika list items tidak bisa diakses)
MOKA_DEFAULT_ITEM_ID=
MOKA_DEFAULT_CATEGORY_ID=
MOKA_DEFAULT_CATEGORY_NAME=Services

# Sales type (opsional). Kalau tidak diisi, server akan call generate_sales_type.
MOKA_SALES_TYPE_ID=
MOKA_SALES_TYPE_NAME=

# Webhook HMAC secret (set in Moka webhook config)
# Leave empty to skip signature verification (not recommended for production)
MOKA_WEBHOOK_SECRET=your_webhook_signing_secret

# OAuth scopes (space-separated)
MOKA_SCOPE=orders:read orders:write customers:read customers:write

# ================================================
# OPEN BILL → SLOT BLOCKING (cegah double booking goshow vs web)
# ================================================
# Buffer (menit) ditambah ke estimated end_time setiap Open Bill walk-in.
# Tujuan: kapster punya waktu transisi/cleanup sebelum customer berikut,
# dan cover ketidakakuratan durasi service. Default 10 menit.
MOKA_OPENBILL_BUFFER_MIN=10

# Window (jam) sebelum schedule "reserved" dari Open Bill di-auto-cancel.
# Skenario: kasir lupa close bill di MokaPOS → tanpa ini slot ke-blok selamanya.
# Default 4 jam setelah end_time → cron tiap 15 menit akan release slot.
MOKA_OPENBILL_STALE_HOURS=4

# Polling intervals
MOKA_PULL_INTERVAL_MINUTES=1
MOKA_RETRY_INTERVAL_MINUTES=2

# ================================================
# FONNTE — WhatsApp Gateway (multi-branch tokens)
# Token per cabang: Settings > Device di dashboard Fonnte
# Setiap token terikat ke 1 nomor WA cabang
# ================================================
FONNTE_TOKEN=<token_bypass>
FONNTE_TOKEN_SUMBER=<token_sumber>
FONNTE_TOKEN_SAMADIKUN=<token_samadikun>
FONNTE_TOKEN_CSB=<token_csb_mall>
FONNTE_TOKEN_TEGAL=<token_tegal>

# Admin WA untuk notifikasi booking (format: 628xxx)
WA_ADMIN_NUMBER=628xxxxxxxxxx

# Cron secret untuk endpoint review-request & reminders
CRON_SECRET=your_cron_secret_here
