# ─── SERVER ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── WHATSAPP CLOUD API ───────────────────────────────
# Dapatkan dari: https://developers.facebook.com/apps/
# → App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
WA_VERIFY_TOKEN=redbox_webhook_secret_2026

# ─── OPENAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# ─── ADMIN ────────────────────────────────────────────
# Format: 628xxxxxxxxxx (no + or spaces)
ADMIN_WHATSAPP=628123456789

# ─── BUSINESS INFO ────────────────────────────────────
BRAND_ADDRESS=Jl. Contoh No. 123, Kota

# ─── BRANCH WA NUMBERS (dispatch forwarding) ──────────
# Nomor WA masing-masing cabang — format: 628xxxxxxxxxx
# Bypass = nomor dispatch utama (no WA pusat saat ini)
WA_BRANCH_BYPASS=628xxxxxxx1
WA_BRANCH_CSB=628xxxxxxx2
WA_BRANCH_SAMADIKUN=628xxxxxxx3
WA_BRANCH_SUMBER=628xxxxxxx4
WA_BRANCH_TEGAL=628xxxxxxx5

# ─── REMINDER SCHEDULER ───────────────────────────────
# Quiet hours: no reminders sent before QUIET_START or after QUIET_END (WIB, 24h format)
# Default: 8 = 08:00, 21 = 21:00
REMINDER_QUIET_START=8
REMINDER_QUIET_END=21
