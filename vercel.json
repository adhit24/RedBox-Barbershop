{
  "outputDirectory": ".",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/moka/cron",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" }
  ],
  "headers": [
    {
      "source": "/Brand_assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
