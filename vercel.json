{
  "outputDirectory": ".",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    },
    "api/ai/analyze.js": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    },
    "api/ai/upload.js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    },
    "api/ai/hairstyle.js": {
      "maxDuration": 300,
      "includeFiles": "server/**"
    },
    "api/ai/generate-image.js": {
      "maxDuration": 120,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/ai/analyze",        "destination": "/api/ai/analyze.js" },
    { "source": "/api/ai/upload",         "destination": "/api/ai/upload.js" },
    { "source": "/api/ai/hairstyle",      "destination": "/api/ai/hairstyle.js" },
    { "source": "/api/ai/generate-image", "destination": "/api/ai/generate-image.js" },
    { "source": "/api/(.*)",              "destination": "/api/[...path].js" }
  ],
  "headers": [
    {
      "source": "/Brand_assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
